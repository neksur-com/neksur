# .env.example — Neksur Core dev cold-start template.
#
# Usage:
#   cp .env.example .env
#   # edit .env to fill in your WorkOS / TLS values when bringing up Phase 2
#   set -a; source .env; set +a
#   go run ./cmd/migrate
#   go run ./cmd/neksur-server
#
# See runbooks/dev-cold-start.md for the full recipe.
# NEVER commit .env (it is gitignored).

# ─── Postgres ────────────────────────────────────────────────────────────
# DSN aligned to docker-compose.yml postgres service credentials.
# sslmode=disable is acceptable for local dev; production uses sslmode=require.
DATABASE_URL=postgres://neksur:neksur_dev@localhost:5432/neksur?sslmode=disable

# ─── Phase 0 observability mode ──────────────────────────────────────────
# Enables OTel gRPC trace exporter + Prometheus /metrics on :9100.
# Requires an OTel collector at localhost:4317 (infra/otel/docker-compose.observability.yml).
# NEKSUR_OBSERVABILITY=1
# NEKSUR_METRICS_ADDR=:9100

# ─── Phase 0.5+ SaaS auth + Phase 1+ gateway + Phase 2 compiler trigger ──
# NEKSUR_SAAS_AUTH=1 is the canonical Phase 2 boot mode. The three WORKOS_*
# values come from your WorkOS dashboard (https://dashboard.workos.com).
# NEKSUR_SAAS_AUTH=1
# WORKOS_API_KEY=sk_test_...
# WORKOS_CLIENT_ID=client_...
# WORKOS_WEBHOOK_SECRET=whsec_...
# NEKSUR_LISTEN_ADDR=:8080

# ─── Phase 2 SQL proxy mTLS listener (OPTIONAL) ──────────────────────────
# All four required to enable the mTLS listener. If any is missing the
# listener is disabled at boot (a structured info log line is emitted).
# Generate dev certs via infra/tls/dev-cert-gen.sh (or use Phase2Fixture
# in tests/testfixture/mtls_cert.go for test runs).
# NEKSUR_TLS_CERT_PATH=./certs/server.crt
# NEKSUR_TLS_KEY_PATH=./certs/server.key
# NEKSUR_CA_BUNDLE_PATH=./certs/ca-bundle.pem
# NEKSUR_SQLPROXY_ADDR=:8443

# ─── Phase 1 L3 detection (OPTIONAL) ─────────────────────────────────────
# NEKSUR_L3_DISPATCH_BUFFER=1024
# NEKSUR_S3_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/...
# NEKSUR_S3_EVENTS_TENANT_ID=00000000-0000-0000-0000-000000000000
# NEKSUR_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Phase 0.5 billing + admin (OPTIONAL) ────────────────────────────────
# STRIPE_WEBHOOK_SECRET is a security best-practice when NEKSUR_SAAS_AUTH=1:
# the /webhooks/stripe handler verifies the signature BEFORE the
# BILLING_ENABLED gate to defeat spoofed-webhook attacks (T-0.5-stripe-spoof).
# BILLING_ENABLED=false
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# WORKOS_INTERNAL_ADMIN_ORG_ID=org_...
# PAGERDUTY_SERVICE_ID=P000000
